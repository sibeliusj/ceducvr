# ─────────────────────────────────────────────────────────────
# CEDUC VR — variáveis de ambiente (projeto Next.js)
# Copie para .env.local (git-ignorado) e preencha com valores REAIS.
# Na Vercel: configurar em Project Settings → Environment Variables.
# NUNCA commitar valores reais. Todos os secrets foram rotacionados na Fase 0.
# ─────────────────────────────────────────────────────────────

# --- Supabase (público: pode ir ao bundle do cliente) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (SECRETO: só server-side, nunca no cliente) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudflare Turnstile (anti-spam dos formulários) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Microsoft Graph (envio de e-mail dos formulários) ---
# Secret ROTACIONADO na Fase 0 — o antigo (exposto no repo PHP) está revogado.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SENDER_EMAIL=no-reply@cvr.org.br

# Destinatários dos formulários (separados por vírgula)
FORM_RECIPIENTS=valeria.duraes@cvr.org.br,comercial@cvr.org.br

# --- Analytics ---
NEXT_PUBLIC_GA_ID=G-C89DNLBN6T
NEXT_PUBLIC_CLARITY_ID=w935c0wdy2

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://cvr.org.br
